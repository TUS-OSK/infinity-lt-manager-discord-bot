{
  "name": "infinity-lt-discord-bot",
  "module": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "bun --watch run src/index.ts",
    "register": "tsx --env-file=.env ./scripts/registerCommands.ts",
    "delete": "tsx --env-file=.env ./scripts/deleteCommands.ts",
    "prisma-fmt": "bunx prisma-case-format --file prisma/schema.prisma"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "prisma": "^6.2.1",
    "prisma-case-format": "^2.2.1",
    "tsx": "^4.19.2"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "discord.js": "^14.17.3",
    "zod": "^3.24.1"
  }
}